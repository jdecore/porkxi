---
import GraficaInteractiva from '../components/GraficaInteractiva.vue';
import TablaResumen from '../components/TablaResumen.vue';
import TarjetasKpiAnimadas from '../components/TarjetasKpiAnimadas.vue';
import AnalisisIA from '../components/AnalisisIA.vue';
import DescargarReporte from '../components/DescargarReporte.vue';
import MonitoreoFuentes from '../components/MonitoreoFuentes.vue';
import '../styles/encabezado.css';
import '../styles/alerta.css';
import '../styles/grafica.css';
import '../styles/frecuencia.css';
import '../styles/detalle.css';
import '../styles/tabla.css';
import '../styles/explicacion.css';
import '../styles/pieDepagina.css';

import { SERIE_COLOMBIA, DETALLE_COLOMBIA, PROBLEMA_DATOS_COLOMBIA } from '../data/colombia';
import { SERIE_USA, DETALLE_USA } from '../data/usa';
import { SERIE_EUROPA, DETALLE_EUROPA } from '../data/europa';

if (!Array.isArray(SERIE_COLOMBIA) || !SERIE_COLOMBIA.length) {
  throw new Error('SERIE_COLOMBIA está vacío o no es un array');
}
if (!Array.isArray(SERIE_USA) || !SERIE_USA.length) {
  throw new Error('SERIE_USA está vacío o no es un array');
}
if (!Array.isArray(SERIE_EUROPA) || !SERIE_EUROPA.length) {
  throw new Error('SERIE_EUROPA está vacío o no es un array');
}

const anos = [2024, 2023, 2022, 2021, 2020, 2019, 2018, 2017, 2016, 2015];
const colombiaRecientes = SERIE_COLOMBIA.filter((d) => Number(d.periodo) >= 2020);
const europaRecientes = SERIE_EUROPA.filter((d) => Number(d.periodo) >= 2020);
const usaRecientes = SERIE_USA.slice(-6);
const baseUrl = import.meta.env.BASE_URL || '/';
const withBase = (path: string) => `${baseUrl}${String(path).replace(/^\/+/, '')}`;
const siteUrl = Astro.site ?? new URL('https://porkxi.com');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(withBase('og-image.png'), siteUrl).toString();
const topEstadosUsa = Array.isArray(DETALLE_USA.estados)
  ? DETALLE_USA.estados.map((estado) => `${estado.nombre}: ${estado.cabezas.toLocaleString()}`).join(' · ')
  : 'Sin dato';
const metodosEncuestaUsa = Array.isArray(DETALLE_USA.metodosEncuesta)
  ? DETALLE_USA.metodosEncuesta.join(', ')
  : 'Sin dato';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="description" content="Inventario porcino Colombia vs Europa vs EE.UU. y la diferencia en apertura de datos oficiales." />
    <meta name="author" content="Juan Enríquez" />
    <meta name="theme-color" content="#F8F5F0" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content="porkξ | Inventario porcino" />
    <meta property="og:description" content="Comparativo de inventario porcino entre Colombia, Europa y EE.UU. con fuentes oficiales." />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="porkξ" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Gráfica comparativa de inventario porcino Colombia, Europa y EE.UU." />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="porkξ | Inventario porcino" />
    <meta name="twitter:description" content="Comparativo de inventario porcino entre Colombia, Europa y EE.UU. con fuentes oficiales." />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Gráfica comparativa de inventario porcino Colombia, Europa y EE.UU." />

    <title>porkξ | Inventario porcino</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&family=Playfair+Display:wght@700;900&family=Poppins:wght@900&family=Sora:wght@400;600;700&display=swap" rel="stylesheet" />
    <script type="module" src="https://cdn.jsdelivr.net/npm/@xenova/transformers@2.17.1/dist/transformers.min.js"></script>

    <style>
      :root {
        --crema: #F9F6F1;
        --crema-oscuro: #F5F5F5;
        --crema-borde: #E8E4E0;
        --tinta: #3A2320;
        --tinta-claro: #5A4A45;
        --colombia: #C96A5B;
        --europa: #0F766E;
        --usa: #1D4ED8;
        --alerta: #C0392B;
        --alerta-fondo: #FEF0EE;
        --cerdo: #C4320A;
        --cerdo-claro: #D4736B;
        --radio: 14px;
        --sombra: 0 10px 28px rgba(59,31,28,0.08);
      }
      *, *::before, *::after { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; scroll-behavior: smooth; }
body { margin: 0; padding: 0; font-family: 'Sora', 'DM Sans', sans-serif; background-color: #F9F6F1; color: var(--tinta); min-height: 100vh; position: relative; }
      .hero-bg { background: #F9F6F1; }
      .contenedor { max-width: 1140px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }
      img, svg { max-width: 100%; height: auto; }
      @media (max-width: 700px) { .contenedor { padding: 0 16px; } }
    </style>
  </head>
  <body>
    <main class="contenedor hero-bg">
      <header class="encabezado">
        <h1 class="encabezado__logo"><span class="encabezado__logo-parte">pork</span><span class="encabezado__logo-xi">ξ</span></h1>
        <p class="encabezado__subtitulo">Inventario porcino de Colombia, UE-27 y EE.UU. en un solo lugar, con fuente.</p>
      </header>
      <section class="explicacion">
        <h2 class="explicacion__titulo">¿Por qué existe esta brecha?</h2>
        <div class="explicacion__grid">
          <div class="explicacion-columna explicacion-columna--colombia">
            <h3 class="explicacion-columna__titulo">🇨🇴 Colombia</h3>
            <p class="explicacion-columna__texto">En Colombia, acceder a información porcina oficial actualizada es prácticamente imposible por canales directos. Los datos están fragmentados entre varias entidades que no se comunican entre sí.</p>
            <p class="explicacion-columna__texto">No existe una fuente gubernamental que ofrezca una API funcional para la serie consolidada nacional.</p>
            <div class="explicacion-destacado">Por eso, los datos de esta visualización provienen de Porcinews, un medio periodístico especializado — no de fuentes gubernamentales directas.</div>
            <div class="explicacion-tabla">
              <table>
                <thead><tr><th>Entidad</th><th>Qué publica</th><th>Problema</th></tr></thead>
                <tbody>
                  {PROBLEMA_DATOS_COLOMBIA.problemas && PROBLEMA_DATOS_COLOMBIA.problemas.length > 0 ? PROBLEMA_DATOS_COLOMBIA.problemas.map((prob) => (
                    <tr><td>{prob.entidad}</td><td>{prob.dato}</td><td><div class="explicacion-tabla__problema"><span class="explicacion-tabla__problema-icono">⚠️</span><span>{prob.problema}</span></div></td></tr>
                  )) : <tr><td colspan="3">No hay datos disponibles.</td></tr>}
                </tbody>
              </table>
            </div>
          </div>

          <div class="explicacion-columna explicacion-columna--europa">
            <h3 class="explicacion-columna__titulo">🇪🇺 Europa (UE-27)</h3>
            <p class="explicacion-columna__texto">Eurostat publica la serie oficial mediante API abierta (`apro_mt_lspig`) con dimensiones estandarizadas.</p>
            <p class="explicacion-columna__texto">Esto permite trazabilidad, automatización y comparabilidad entre países sin depender de scraping manual de PDFs.</p>
          </div>

          <div class="explicacion-columna explicacion-columna--usa">
            <h3 class="explicacion-columna__titulo">🇺🇸 EE.UU.</h3>
            <p class="explicacion-columna__texto">La Livestock Mandatory Reporting Act obliga a reportar al USDA. Hay publicaciones periódicas, verificables y con calendario público.</p>
            <p class="explicacion-columna__texto">La disponibilidad trimestral facilita monitoreo continuo y análisis oportuno del sector porcino.</p>
          </div>
        </div>
      </section>
      <MonitoreoFuentes client:idle />
      <AnalisisIA client:idle />
      <GraficaInteractiva client:idle />

<div class="comparativa-frecuencia">
        <div class="frecuencia-card frecuencia-card--colombia">
          <div class="frecuencia-card__encabezado"><span class="frecuencia-card__icono">🇨🇴</span><h3 class="frecuencia-card__titulo">Colombia</h3></div>
          <span class="frecuencia-card__pildora">Anual · con retraso</span>
          <p class="frecuencia-card__descripcion">Los datos más recientes provienen de Porcinews, un medio especializado.</p>
          <div class="frecuencia-timeline">
            {colombiaRecientes.map((d) => (
              <div class="frecuencia-timeline__item">
                <span class={`frecuencia-timeline__punto ${d.advertencia ? 'frecuencia-timeline__punto--alerta' : 'frecuencia-timeline__punto--colombia'}`}></span>
                <div class="frecuencia-timeline__periodo">{d.periodo}</div>
                <div class={`frecuencia-timeline__valor ${d.advertencia ? 'frecuencia-timeline__valor--alerta' : ''}`}>{d.valor.toLocaleString()} cabezas {d.advertencia ? '⚠️ mismo dato de 2022' : d.ultimoDato ? '(Porcinews, ene 2026)' : '✓'}</div>
              </div>
            ))}
          </div>
          <p class="frecuencia-card__fuente">Fuente: Porcinews</p>
        </div>

        <div class="frecuencia-card frecuencia-card--europa">
          <div class="frecuencia-card__encabezado"><span class="frecuencia-card__icono">🇪🇺</span><h3 class="frecuencia-card__titulo">Europa (UE-27)</h3></div>
          <span class="frecuencia-card__pildora">Anual · APIabierta</span>
          <p class="frecuencia-card__descripcion">Serie oficial publicada por Eurostat vía API.</p>
          <div class="frecuencia-timeline">
            {europaRecientes.map((d) => (
              <div class="frecuencia-timeline__item">
                <span class="frecuencia-timeline__punto frecuencia-timeline__punto--europa"></span>
                <div class="frecuencia-timeline__periodo">{d.periodo}</div>
                <div class="frecuencia-timeline__valor">{d.valor.toLocaleString()} cabezas {d.ultimoDato ? '✓ dato oficial más reciente' : '✓'}</div>
              </div>
            ))}
          </div>
          <p class="frecuencia-card__fuente">Fuente: Eurostat (apro_mt_lspig)</p>
        </div>

        <div class="frecuencia-card frecuencia-card--usa">
          <div class="frecuencia-card__encabezado"><span class="frecuencia-card__icono">🇺🇸</span><h3 class="frecuencia-card__titulo">Estados Unidos</h3></div>
          <span class="frecuencia-card__pildora">Trimestral · obligatorio por ley</span>
          <p class="frecuencia-card__descripcion">Reporte obligatorio bajo la Livestock Mandatory Reporting Act.</p>
          <div class="frecuencia-timeline">
            {usaRecientes.map((d) => (
              <div class="frecuencia-timeline__item">
                <span class="frecuencia-timeline__punto frecuencia-timeline__punto--usa"></span>
                <div class="frecuencia-timeline__periodo">{d.periodo}</div>
                <div class="frecuencia-timeline__valor">{d.valor.toLocaleString()} cabezas {d.ultimoDato ? '(último reporte)' : '✓'}</div>
              </div>
            ))}
          </div>
          <p class="frecuencia-card__fuente">Fuente: USDA NASS</p>
        </div>
      </div>

      <div class="comparativa-frecuencia">
        <div class="frecuencia-card frecuencia-card--colombia">
          <div class="frecuencia-card__encabezado"><span class="frecuencia-card__icono">🇨🇴</span><h3 class="frecuencia-card__titulo">Colombia</h3></div>
          <span class="frecuencia-card__pildora">Anual · con retraso</span>
          <p class="frecuencia-card__descripcion">Los datos más recientes provienen de Porcinews, un medio especializado.</p>
          <div class="frecuencia-timeline">
            {colombiaRecientes.map((d) => (
              <div class="frecuencia-timeline__item">
                <span class={`frecuencia-timeline__punto ${d.advertencia ? 'frecuencia-timeline__punto--alerta' : 'frecuencia-timeline__punto--colombia'}`}></span>
                <div class="frecuencia-timeline__periodo">{d.periodo}</div>
                <div class={`frecuencia-timeline__valor ${d.advertencia ? 'frecuencia-timeline__valor--alerta' : ''}`}>{d.valor.toLocaleString()} cabezas {d.advertencia ? '⚠️ mismo dato de 2022' : d.ultimoDato ? '(Porcinews, ene 2026)' : '✓'}</div>
              </div>
            ))}
          </div>
          <p class="frecuencia-card__fuente">Fuente: Porcinews</p>
        </div>

        <div class="frecuencia-card frecuencia-card--europa">
          <div class="frecuencia-card__encabezado"><span class="frecuencia-card__icono">🇪🇺</span><h3 class="frecuencia-card__titulo">Europa (UE-27)</h3></div>
          <span class="frecuencia-card__pildora">Anual · API abierta</span>
          <p class="frecuencia-card__descripcion">Serie oficial publicada por Eurostat vía API.</p>
          <div class="frecuencia-timeline">
            {europaRecientes.map((d) => (
              <div class="frecuencia-timeline__item">
                <span class="frecuencia-timeline__punto frecuencia-timeline__punto--europa"></span>
                <div class="frecuencia-timeline__periodo">{d.periodo}</div>
                <div class="frecuencia-timeline__valor">{d.valor.toLocaleString()} cabezas {d.ultimoDato ? '✓ dato oficial más reciente' : '✓'}</div>
              </div>
            ))}
          </div>
          <p class="frecuencia-card__fuente">Fuente: Eurostat (apro_mt_lspig)</p>
        </div>

        <div class="frecuencia-card frecuencia-card--usa">
          <div class="frecuencia-card__encabezado"><span class="frecuencia-card__icono">🇺🇸</span><h3 class="frecuencia-card__titulo">Estados Unidos</h3></div>
          <span class="frecuencia-card__pildora">Trimestral · obligatorio por ley</span>
          <p class="frecuencia-card__descripcion">Reporte obligatorio bajo la Livestock Mandatory Reporting Act.</p>
          <div class="frecuencia-timeline">
            {usaRecientes.map((d) => (
              <div class="frecuencia-timeline__item">
                <span class="frecuencia-timeline__punto frecuencia-timeline__punto--usa"></span>
                <div class="frecuencia-timeline__periodo">{d.periodo}</div>
                <div class="frecuencia-timeline__valor">{d.valor.toLocaleString()} cabezas {d.ultimoDato ? '(último reporte)' : '✓'}</div>
              </div>
            ))}
          </div>
          <p class="frecuencia-card__fuente">Fuente: USDA NASS</p>
        </div>
</div>

      <footer class="pie-pagina">
        <div class="pie-pagina__fuentes">
          <div class="pie-pagina__fuente">
            <div class="pie-pagina__fuente-titulo">🇨🇴 Colombia</div>
            <div class="pie-pagina__fuente-nota">Fuente periodística especializada.</div>
            <a href={DETALLE_COLOMBIA.enlace} target="_blank" rel="noopener noreferrer" class="pie-pagina__enlace">Porcinews (ene 2026)</a>
          </div>
          <div class="pie-pagina__fuente">
            <div class="pie-pagina__fuente-titulo">🇪🇺 Europa</div>
            <a href={DETALLE_EUROPA.enlace} target="_blank" rel="noopener noreferrer" class="pie-pagina__enlace">Eurostat API (apro_mt_lspig)</a>
          </div>
          <div class="pie-pagina__fuente">
            <div class="pie-pagina__fuente-titulo">🇺🇸 EE.UU.</div>
            <a href={DETALLE_USA.enlace} target="_blank" rel="noopener noreferrer" class="pie-pagina__enlace">USDA NASS</a>
          </div>
        </div>

        <hr class="pie-pagina__separador" />
        <div class="pie-pagina__creditos">Hecho por Juan Enríquez con ayuda de IA</div>
        <p class="pie-pagina__creditos-nota">Todos los datos fueron verificados contra fuentes oficiales disponibles públicamente.</p>
        <div class="pie-pagina__marca">pork<span class="pie-pagina__marca-xi">ξ</span> · 2026</div>
      </footer>
    </main>
  </body>
</html>
