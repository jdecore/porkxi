---
import GraficaInteractiva from '../components/GraficaInteractiva.vue';
import TarjetasKpiAnimadas from '../components/TarjetasKpiAnimadas.vue';
import AnalisisIA from '../components/AnalisisIA.vue';
import MonitoreoFuentes from '../components/MonitoreoFuentes.vue';
import InsightsComparativas from '../components/InsightsComparativas.vue';

import '../styles/encabezado.css';
import '../styles/alerta.css';
import '../styles/grafica.css';
import '../styles/frecuencia.css';
import '../styles/detalle.css';
import '../styles/tabla.css';
import '../styles/explicacion.css';
import '../styles/pieDepagina.css';

import { SERIE_COLOMBIA, DETALLE_COLOMBIA, PROBLEMA_DATOS_COLOMBIA } from '../data/colombia';
import { SERIE_USA, DETALLE_USA } from '../data/usa';
import { SERIE_EUROPA, DETALLE_EUROPA } from '../data/europa';

if (!Array.isArray(SERIE_COLOMBIA) || !SERIE_COLOMBIA.length) {
  throw new Error('SERIE_COLOMBIA está vacío o no es un array');
}
if (!Array.isArray(SERIE_USA) || !SERIE_USA.length) {
  throw new Error('SERIE_USA está vacío o no es un array');
}
if (!Array.isArray(SERIE_EUROPA) || !SERIE_EUROPA.length) {
  throw new Error('SERIE_EUROPA está vacío o no es un array');
}

const anos = [2024, 2023, 2022, 2021, 2020, 2019, 2018, 2017, 2016, 2015];
const colombiaRecientes = SERIE_COLOMBIA.filter((d) => Number(d.periodo) >= 2020);
const europaRecientes = SERIE_EUROPA.filter((d) => Number(d.periodo) >= 2020);
const usaRecientes = SERIE_USA.slice(-6);
const baseUrl = import.meta.env.BASE_URL || '/';
const withBase = (path: string) => `${baseUrl}${String(path).replace(/^\/+/, '')}`;
const siteUrl = Astro.site ?? new URL('https://porkxi.com');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(withBase('og-image.png'), siteUrl).toString();
const topEstadosUsa = Array.isArray(DETALLE_USA.estados)
  ? DETALLE_USA.estados.map((estado) => `${estado.nombre}: ${estado.cabezas.toLocaleString()}`).join(' · ')
  : 'Sin dato';
const metodosEncuestaUsa = Array.isArray(DETALLE_USA.metodosEncuesta)
  ? DETALLE_USA.metodosEncuesta.join(', ')
  : 'Sin dato';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="description" content="Inventario porcino Colombia vs Europa vs EE.UU. y la diferencia en apertura de datos oficiales." />
    <meta name="author" content="Juan Enríquez" />
    <meta name="theme-color" content="#FDF0EE" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content="porkξ | Inventario porcino" />
    <meta property="og:description" content="Comparativo de inventario porcino entre Colombia, Europa y EE.UU. con fuentes oficiales." />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="porkξ" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Gráfica comparativa de inventario porcino Colombia, Europa y EE.UU." />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="porkξ | Inventario porcino" />
    <meta name="twitter:description" content="Comparativo de inventario porcino entre Colombia, Europa y EE.UU. con fuentes oficiales." />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Gráfica comparativa de inventario porcino Colombia, Europa y EE.UU." />

    <title>porkξ | Inventario porcino</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@700;900&display=swap" rel="stylesheet" />

    <style>
      :root {
        --crema: #FDF0EE;
        --crema-oscuro: #F7E0DC;
        --crema-borde: #EEC9C4;
        --tinta: #3B1F1C;
        --tinta-claro: #7A4A44;
        --colombia: #F5A800;
        --europa: #0EA5A4;
        --usa: #2563EB;
        --alerta: #C0392B;
        --alerta-fondo: #FEF0EE;
        --cerdo: #D4736B;
        --cerdo-claro: #E8A09A;
        --radio: 14px;
        --sombra: 0 10px 28px rgba(59,31,28,0.08);
      }
      *, *::before, *::after { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; scroll-behavior: smooth; }
      body { margin: 0; padding: 0; font-family: 'DM Sans', sans-serif; background-color: var(--crema); color: var(--tinta); min-height: 100vh; position: relative; }
      body::before { content: ''; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E"); opacity: 0.03; pointer-events: none; z-index: 0; }
      .contenedor { max-width: 1100px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }
      img, svg { max-width: 100%; height: auto; }
      @media (max-width: 700px) { .contenedor { padding: 0 16px; } }
    </style>
  </head>
  <body>
    <main class="contenedor">
      <header class="encabezado">
        <h1 class="encabezado__logo"><span class="encabezado__logo-parte">pork</span><span class="encabezado__logo-xi">ξ</span></h1>
        <p class="encabezado__subtitulo">Inventario porcino Colombia vs Europa vs EE.UU. — y la brecha en transparencia de datos oficiales.</p>
        <div class="encabezado__badges">
          <span class="encabezado__badge encabezado__badge--colombia">Porcinews (ene 2026)</span>
          <span class="encabezado__badge encabezado__badge--europa">Eurostat (API)</span>
          <span class="encabezado__badge encabezado__badge--usa">USDA NASS (dic 2025)</span>
          <span class="encabezado__badge encabezado__badge--datos">Datos verificados</span>
        </div>
      </header>

      <div class="banner-alerta">
        <span class="banner-alerta__icono">⚠️</span>
        <p class="banner-alerta__texto">Europa (Eurostat) y EE.UU. (USDA) publican inventario porcino con fuentes oficiales y trazables. En Colombia, los datos siguen fragmentados y sin API pública equivalente, por lo que el último dato consolidado disponible proviene de Porcinews.</p>
      </div>

      <TarjetasKpiAnimadas client:idle />
      <GraficaInteractiva client:idle />
      <AnalisisIA client:idle />
      <MonitoreoFuentes client:idle />
      <InsightsComparativas client:visible />

      <div class="comparativa-frecuencia">
        <div class="frecuencia-card frecuencia-card--colombia">
          <div class="frecuencia-card__encabezado"><span class="frecuencia-card__icono">🇨🇴</span><h3 class="frecuencia-card__titulo">Colombia</h3></div>
          <span class="frecuencia-card__pildora">Anual · con retraso</span>
          <p class="frecuencia-card__descripcion">Los datos más recientes provienen de Porcinews, un medio especializado.</p>
          <div class="frecuencia-timeline">
            {colombiaRecientes.map((d) => (
              <div class="frecuencia-timeline__item">
                <span class={`frecuencia-timeline__punto ${d.advertencia ? 'frecuencia-timeline__punto--alerta' : 'frecuencia-timeline__punto--colombia'}`}></span>
                <div class="frecuencia-timeline__periodo">{d.periodo}</div>
                <div class={`frecuencia-timeline__valor ${d.advertencia ? 'frecuencia-timeline__valor--alerta' : ''}`}>{d.valor.toLocaleString()} cabezas {d.advertencia ? '⚠️ mismo dato de 2022' : d.ultimoDato ? '(Porcinews, ene 2026)' : '✓'}</div>
              </div>
            ))}
          </div>
          <p class="frecuencia-card__fuente">Fuente: Porcinews</p>
        </div>

        <div class="frecuencia-card frecuencia-card--europa">
          <div class="frecuencia-card__encabezado"><span class="frecuencia-card__icono">🇪🇺</span><h3 class="frecuencia-card__titulo">Europa (UE-27)</h3></div>
          <span class="frecuencia-card__pildora">Anual · API abierta</span>
          <p class="frecuencia-card__descripcion">Serie oficial publicada por Eurostat vía API.</p>
          <div class="frecuencia-timeline">
            {europaRecientes.map((d) => (
              <div class="frecuencia-timeline__item">
                <span class="frecuencia-timeline__punto frecuencia-timeline__punto--europa"></span>
                <div class="frecuencia-timeline__periodo">{d.periodo}</div>
                <div class="frecuencia-timeline__valor">{d.valor.toLocaleString()} cabezas {d.ultimoDato ? '✓ dato oficial más reciente' : '✓'}</div>
              </div>
            ))}
          </div>
          <p class="frecuencia-card__fuente">Fuente: Eurostat (apro_mt_lspig)</p>
        </div>

        <div class="frecuencia-card frecuencia-card--usa">
          <div class="frecuencia-card__encabezado"><span class="frecuencia-card__icono">🇺🇸</span><h3 class="frecuencia-card__titulo">Estados Unidos</h3></div>
          <span class="frecuencia-card__pildora">Trimestral · obligatorio por ley</span>
          <p class="frecuencia-card__descripcion">Reporte obligatorio bajo la Livestock Mandatory Reporting Act.</p>
          <div class="frecuencia-timeline">
            {usaRecientes.map((d) => (
              <div class="frecuencia-timeline__item">
                <span class="frecuencia-timeline__punto frecuencia-timeline__punto--usa"></span>
                <div class="frecuencia-timeline__periodo">{d.periodo}</div>
                <div class="frecuencia-timeline__valor">{d.valor.toLocaleString()} cabezas {d.ultimoDato ? '(último reporte)' : '✓'}</div>
              </div>
            ))}
          </div>
          <p class="frecuencia-card__fuente">Fuente: USDA NASS</p>
        </div>
      </div>

      <section class="detalle-seccion">
        <h2 class="detalle-seccion__titulo">Detalle del último reporte oficial</h2>
        <div class="detalle-grid">
          <div class="detalle-card detalle-card--colombia">
            <div class="detalle-card__aviso">⚠️ Fuente: Porcinews (medio periodístico especializado).</div>
            <div class="detalle-card__encabezado"><span class="detalle-card__icono">🇨🇴</span><h3 class="detalle-card__titulo">Colombia — {DETALLE_COLOMBIA.fecha}</h3></div>
            <div class="detalle-metricas">
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Total inventario</span><span class="detalle-metrica__valor">{DETALLE_COLOMBIA.totalCabezas.toLocaleString()} cabezas</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Total predios</span><span class="detalle-metrica__valor">{DETALLE_COLOMBIA.totalPredios.toLocaleString()}</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Predios traspatio</span><span class="detalle-metrica__valor">{DETALLE_COLOMBIA.traspatio.cantidad.toLocaleString()} ({DETALLE_COLOMBIA.traspatio.porcentaje}%)</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Comercial familiar</span><span class="detalle-metrica__valor">{DETALLE_COLOMBIA.comercialFamiliar.cantidad.toLocaleString()} ({DETALLE_COLOMBIA.comercialFamiliar.porcentaje}%)</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Comercial industrial</span><span class="detalle-metrica__valor">{DETALLE_COLOMBIA.comercialIndustrial.cantidad.toLocaleString()} ({DETALLE_COLOMBIA.comercialIndustrial.porcentaje}%)</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Granjas tecnificadas</span><span class="detalle-metrica__valor">{DETALLE_COLOMBIA.tecnificadas.cantidad.toLocaleString()} ({DETALLE_COLOMBIA.tecnificadas.porcentaje}%)</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Carne 2024</span><span class="detalle-metrica__valor">{DETALLE_COLOMBIA.carne2024Toneladas.toLocaleString()} t</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Variación carne</span><span class="detalle-metrica__valor">+{DETALLE_COLOMBIA.carne2024Variacion}%</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Beneficio 2024</span><span class="detalle-metrica__valor">{DETALLE_COLOMBIA.beneficio2024Cabezas.toLocaleString()} cabezas</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Variación beneficio</span><span class="detalle-metrica__valor">+{DETALLE_COLOMBIA.beneficio2024Variacion}%</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Fuente</span><span class="detalle-metrica__valor">{DETALLE_COLOMBIA.fuente}</span></div>
            </div>
            <p class="detalle-card__subtitulo">{DETALLE_COLOMBIA.notaFuente}</p>
            <a href={DETALLE_COLOMBIA.enlace} target="_blank" rel="noopener noreferrer" class="detalle-card__enlace">Ver fuente: Porcinews</a>
          </div>

          <div class="detalle-card detalle-card--europa">
            <div class="detalle-card__encabezado"><span class="detalle-card__icono">🇪🇺</span><h3 class="detalle-card__titulo">Europa — {DETALLE_EUROPA.fechaDato}</h3></div>
            <p class="detalle-card__subtitulo">Dataset {DETALLE_EUROPA.dataset} · Eurostat</p>
            <div class="detalle-metricas">
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Total inventario</span><span class="detalle-metrica__valor">{DETALLE_EUROPA.totalCabezas.toLocaleString()} cabezas</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Variación anual</span><span class="detalle-metrica__valor">{DETALLE_EUROPA.variacionAnualPct}% vs 2023</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Frecuencia</span><span class="detalle-metrica__valor">{DETALLE_EUROPA.frecuencia}</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Cobertura</span><span class="detalle-metrica__valor">{DETALLE_EUROPA.cobertura}</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Unidad</span><span class="detalle-metrica__valor">{DETALLE_EUROPA.unidad}</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Actualización API</span><span class="detalle-metrica__valor">{DETALLE_EUROPA.fechaActualizacionApi}</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Fuente</span><span class="detalle-metrica__valor">{DETALLE_EUROPA.fuente}</span></div>
            </div>
            <p class="detalle-card__subtitulo">{DETALLE_EUROPA.notaFuente}</p>
            <a href={DETALLE_EUROPA.enlace} target="_blank" rel="noopener noreferrer" class="detalle-card__enlace">Ver dataset oficial</a>
          </div>

          <div class="detalle-card detalle-card--usa">
            <div class="detalle-card__encabezado"><span class="detalle-card__icono">🇺🇸</span><h3 class="detalle-card__titulo">EE.UU. — {DETALLE_USA.fechaDato}</h3></div>
            <p class="detalle-card__subtitulo">Publicado el {DETALLE_USA.fechaPublicacion} · USDA NASS</p>
            <div class="detalle-metricas">
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Total inventario</span><span class="detalle-metrica__valor">{DETALLE_USA.totalCabezas.toLocaleString()} cabezas (+{DETALLE_USA.variacionAnualPct}% vs dic 2024)</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Cerdos de mercado</span><span class="detalle-metrica__valor">{DETALLE_USA.cerDosMercado.toLocaleString()}</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Reproductores</span><span class="detalle-metrica__valor">{DETALLE_USA.reproductores.toLocaleString()}</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Lechones destetados</span><span class="detalle-metrica__valor">{DETALLE_USA.cerdosDestetados.toLocaleString()}</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Promedio camada</span><span class="detalle-metrica__valor">{DETALLE_USA.promedioLechonesPorCamada} lechones</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Próximo reporte</span><span class="detalle-metrica__valor">{DETALLE_USA.proximoReporte}</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Sows farrow dic-feb</span><span class="detalle-metrica__valor">{DETALLE_USA.sowsFarroDicFeb.toLocaleString()}</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Sows farrow mar-may</span><span class="detalle-metrica__valor">{DETALLE_USA.sowsFarroMarMay.toLocaleString()}</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Operadores encuestados</span><span class="detalle-metrica__valor">{DETALLE_USA.operadoresEncuestados.toLocaleString()}</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Métodos encuesta</span><span class="detalle-metrica__valor">{metodosEncuestaUsa}</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Top estados</span><span class="detalle-metrica__valor">{topEstadosUsa}</span></div>
              <div class="detalle-metrica"><span class="detalle-metrica__etiqueta">Fuente</span><span class="detalle-metrica__valor">{DETALLE_USA.fuente}</span></div>
            </div>
            <a href={DETALLE_USA.enlace} target="_blank" rel="noopener noreferrer" class="detalle-card__enlace">Ver reporte oficial</a>
          </div>
        </div>
      </section>

      <section class="tabla-historica">
        <h2 class="tabla-historica__titulo">Histórico año a año</h2>
        <p class="tabla-historica__subtitulo">Comparativo de los últimos diez años.</p>
        <div class="tabla-contenedor">
          <table class="tabla">
            <thead class="tabla__encabezado"><tr><th>Año</th><th>Colombia</th><th>UE-27</th><th>EE.UU. Dic</th><th>Estado</th></tr></thead>
            <tbody class="tabla__cuerpo">
              {anos.map((ano) => {
                const datoColombia = SERIE_COLOMBIA.find((d) => d.periodo === String(ano));
                const datoEuropa = SERIE_EUROPA.find((d) => d.periodo === String(ano));
                const datoUsa = SERIE_USA.find((d) => d.periodo === `Dic ${ano}`);
                const es2023 = ano === 2023;
                const es2024 = ano === 2024;
                return (
                  <tr class={es2023 ? 'tabla__fila--alerta' : es2024 ? 'tabla__fila--reciente' : ''}>
                    <td>{ano}</td>
                    <td class="tabla__cabezas">{datoColombia ? datoColombia.valor.toLocaleString() : '—'}</td>
                    <td class="tabla__cabezas">{datoEuropa ? datoEuropa.valor.toLocaleString() : '—'}</td>
                    <td class="tabla__cabezas">{datoUsa ? datoUsa.valor.toLocaleString() : '—'}</td>
                    <td>
                      {es2023 && <span class="tabla__estado tabla__estado--alerta">⚠️ COL duplicado</span>}
                      {es2024 && <span class="tabla__estado tabla__estado--reciente">✓ COL + UE actualizados</span>}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        <div class="tabla__pie"><span>Colombia: Porcinews</span><span>UE-27: Eurostat</span><span>EE.UU.: USDA NASS</span></div>
      </section>

      <section class="explicacion">
        <h2 class="explicacion__titulo">¿Por qué existe esta brecha?</h2>
        <div class="explicacion__grid">
          <div class="explicacion-columna explicacion-columna--colombia">
            <h3 class="explicacion-columna__titulo">🇨🇴 Colombia</h3>
            <p class="explicacion-columna__texto">Acceder a información porcina oficial actualizada sigue siendo difícil. Los datos están fragmentados entre ICA, DANE, Porkcolombia e INVIMA.</p>
            <p class="explicacion-columna__texto">No existe una API pública y estable equivalente a USDA o Eurostat para la serie consolidada nacional.</p>
            <p class="explicacion-columna__texto">{PROBLEMA_DATOS_COLOMBIA.descripcion}</p>
            <div class="explicacion-destacado">Por eso, esta visualización usa Porcinews como fuente de referencia para el último dato disponible.</div>
            <div class="explicacion-tabla">
              <table>
                <thead><tr><th>Entidad</th><th>Qué publica</th><th>Problema</th></tr></thead>
                <tbody>
                  {PROBLEMA_DATOS_COLOMBIA.problemas && PROBLEMA_DATOS_COLOMBIA.problemas.length > 0 ? PROBLEMA_DATOS_COLOMBIA.problemas.map((prob) => (
                    <tr><td>{prob.entidad}</td><td>{prob.dato}</td><td><div class="explicacion-tabla__problema"><span class="explicacion-tabla__problema-icono">⚠️</span><span>{prob.problema}</span></div></td></tr>
                  )) : <tr><td colspan="3">No hay datos disponibles.</td></tr>}
                </tbody>
              </table>
            </div>
          </div>

          <div class="explicacion-columna explicacion-columna--europa">
            <h3 class="explicacion-columna__titulo">🇪🇺 Europa (UE-27)</h3>
            <p class="explicacion-columna__texto">Eurostat publica la serie oficial mediante API abierta (`apro_mt_lspig`) con dimensiones estandarizadas.</p>
            <p class="explicacion-columna__texto">Esto permite trazabilidad, automatización y comparabilidad entre países sin depender de scraping manual de PDFs.</p>
          </div>

          <div class="explicacion-columna explicacion-columna--usa">
            <h3 class="explicacion-columna__titulo">🇺🇸 EE.UU.</h3>
