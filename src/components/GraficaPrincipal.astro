---
import { serieColombia, serieUSA, serieEuropa } from '../lib/datos-grafico.js';
import '../styles/grafica.css';

const width = 756;
const height = 476;
const areaAncho = 816;
const areaAlto = 340;
const paddingX = 86;

const maxValor = 150;
const puntosColombia = serieColombia.map((d, i) => {
  const x = paddingX + i * (areaAncho / (serieColombia.length - 1));
  const y = 340 - (d.valor / 1e6 / maxValor) * areaAlto + 56;
  return { x, y };
});

const puntosUsa = serieUSA.map((d, i) => {
  const x = paddingX + i * (areaAncho / (serieUSA.length - 1));
  const y = 340 - (d.valor / 1e6 / maxValor) * areaAlto + 56;
  return { x, y };
});

const puntosEuropa = serieEuropa.map((d, i) => {
  const x = paddingX + i * (areaAncho / (serieEuropa.length - 1));
  const y = 340 - (d.valor / 1e6 / maxValor) * areaAlto + 56;
  return { x, y };
});

const colombiaPoly = puntosColombia.map(p => `${p.x},${p.y}`).join(' ');
const usaPoly = puntosUsa.map(p => `${p.x},${p.y}`).join(' ');
const europaPoly = puntosEuropa.map(p => `${p.x},${p.y}`).join(' ');
const allPeriodos = serieColombia.map(d => d.periodo);
---

<section class="grafica-card" aria-labelledby="grafica-titulo">
  <h2 id="grafica-titulo" class="grafica-card__titulo">Inventario histórico comparado</h2>
  <p class="grafica-card__subtitulo">En millones de cabezas.</p>
  
  <div class="grafica-contenedor">
    <svg class="grafica-svg" viewBox={`0 0 ${width} ${height}`} preserveAspectRatio="xMidYMid meet" role="img" aria-label="Gráfica de inventario porcino Colombia, Europa y EE.UU.">
      <title>Inventario histórico porcino: Colombia, Europa y EE.UU.</title>
      <desc>Gráfica de líneas que compara el inventario porcino en Colombia, Europa (UE-27) y EE.UU.</desc>
      
      <g class="grafica-grid">
        {Array.from({ length: 5 }).map((_, i) => (
          <line x1={paddingX} y1={56 + 340 * i / 4} x2={756} y2={56 + 340 * i / 4} stroke="#EEC9C4" stroke-dasharray="3,3" />
        ))}
      </g>
      
      <g class="grafica-y-axis">
        {['0', '40M', '80M', '120M', '150M'].map((label, i) => (
          <text x={69} y={56 + 340 * i / 4} text-anchor="end" dominant-baseline="middle" font-size="13" fill="#7A4A44">{label}</text>
        ))}
      </g>
      
      <g class="grafica-x-axis">
        <line x1={86} y1={420} x2={756} y2={420} stroke="#EEC9C4" stroke-width="1" />
        {allPeriodos.filter((_, i) => i % 2 === 0 || i === allPeriodos.length - 1).map((label, i) => (
          <text x={86 + i * 94} y={455} text-anchor="middle" font-size="12" fill="#7A4A44" transform={`rotate(-40, ${86 + i * 94}, 455)`}>{label}</text>
        ))}
      </g>
      
      <polyline points={usaPoly} fill="none" stroke="#2563EB" stroke-width="3.5" stroke-linecap="round" />
      <polyline points={europaPoly} fill="none" stroke="#0EA5A4" stroke-width="3.5" stroke-linecap="round" />
      <polyline points={colombiaPoly} fill="none" stroke="#F5A800" stroke-width="3.5" stroke-linecap="round" />
      
      {puntosColombia.map((p) => (
        <circle cx={p.x} cy={p.y} r="5" fill="#F5A800" />
      ))}
      {puntosEuropa.map((p) => (
        <circle cx={p.x} cy={p.y} r="5" fill="#0EA5A4" />
      ))}
      {puntosUsa.map((p) => (
        <circle cx={p.x} cy={p.y} r="5" fill="#2563EB" />
      ))}
      
      <g transform="translate(756, 28)">
        <line x1="0" y1="0" x2="24" y2="0" stroke="#F5A800" stroke-width="3" />
        <circle cx="12" cy="0" r="4" fill="#F5A800" />
        <text x="32" y="4" font-size="12" fill="#3B1F1C" font-weight="500">Colombia</text>
        
        <line x1="110" y1="0" x2="134" y2="0" stroke="#0EA5A4" stroke-width="3" />
        <circle cx="122" cy="0" r="4" fill="#0EA5A4" />
        <text x="142" y="4" font-size="12" fill="#3B1F1C" font-weight="500">Europa</text>

        <line x1="210" y1="0" x2="234" y2="0" stroke="#2563EB" stroke-width="3" />
        <circle cx="222" cy="0" r="4" fill="#2563EB" />
        <text x="242" y="4" font-size="12" fill="#3B1F1C" font-weight="500">USA</text>
      </g>
    </svg>
  </div>
</section>
